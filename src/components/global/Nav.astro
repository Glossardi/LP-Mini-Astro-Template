---
import brand from "@data/brand";

interface Props {
  /** Landing page mode: logo left, single CTA right — no distraction links */
  landing?: boolean;
  ctaText?: string;
  ctaHref?: string;
  minimal?: boolean;
}

const {
  landing = false,
  ctaText = "Anmelden",
  ctaHref = "#lead-form",
  minimal = false,
} = Astro.props;
---

<a class="skip-link" href="#main-content">Zum Hauptinhalt springen</a>

<div class="nav-shell">
  <header class="nav" id="site-nav">
    <div class="nav__inner container">
      {
        landing ? (
          <>
            <a class="nav__logo nav__logo--left" href={brand.url} aria-label={`${brand.companyShort} — Website`}>
              <img src={brand.logo} alt={brand.logoAlt} width="160" height="35" loading="eager" />
            </a>
            <a class="btn btn--coral nav__cta" href={ctaHref}>{ctaText}</a>
          </>
        ) : (
          <>
            {
              !minimal ? (
                <nav class="nav__side nav__side--left" aria-label="Navigation links">
                  {brand.nav.left.map((link) => (
                    <a class="nav__link" href={link.href}>{link.label}</a>
                  ))}
                </nav>
              ) : (
                <div class="nav__side nav__side--left" aria-hidden="true" />
              )
            }

            <a class="nav__logo" href={brand.url} aria-label={`${brand.companyShort} — Website`}>
              <img class="nav__logo-img" src={brand.logo} alt={brand.logoAlt} width="160" height="35" loading="eager" />
            </a>

            {
              !minimal ? (
                <nav class="nav__side nav__side--right" aria-label="Navigation rechts">
                  {brand.nav.right.map((link) => (
                    <a class="nav__link" href={link.href}>{link.label}</a>
                  ))}
                </nav>
              ) : (
                <div class="nav__side nav__side--right" aria-hidden="true" />
              )
            }
          </>
        )
      }
    </div>
  </header>
</div>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--color-black);
    color: var(--color-white);
    z-index: 1000;
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .skip-link:focus {
    top: 0.5rem;
  }

  .nav-shell {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav {
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4.5rem;
    gap: 1rem;
  }

  .nav__inner:not(:has(.nav__logo--left)) {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
  }

  .nav__side {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .nav__side--right {
    justify-content: flex-end;
  }

  .nav__link {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-black);
    white-space: nowrap;
  }

  .nav__link:hover {
    opacity: 0.65;
  }

  .nav__logo {
    justify-self: center;
    display: inline-flex;
    text-decoration: none;
  }

  .nav__logo--left {
    justify-self: auto;
  }

  .nav__logo img,
  .nav__logo-img {
    height: 1.2rem;
    width: auto;
  }

  .nav__cta {
    padding: 0.75rem 1.25rem;
    min-height: auto;
    font-size: var(--text-xs);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .nav__logo img,
    .nav__logo-img {
      height: 1.32rem;
    }
  }
</style>

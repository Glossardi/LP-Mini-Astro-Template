---
import type { LandingPageData } from "@lib/types";

interface Props {
  page: LandingPageData;
  class?: string;
}

const { page, class: className = "" } = Astro.props;
---

<div class:list={["pricing-card", className]}>
  {page.pricing_eyebrow && <p class="pricing-card__eyebrow">{page.pricing_eyebrow}</p>}
  {page.pricing_label && <p class="pricing-card__label">{page.pricing_label}</p>}
  <p
    class="pricing-card__amount"
    aria-label={`${page.pricing_amount} ${page.pricing_currency ?? "€"}`}
  >
    <span class="pricing-card__currency">{page.pricing_currency ?? "€"}</span>
    {page.pricing_amount}
  </p>
  {page.pricing_text && <p class="pricing-card__text">{page.pricing_text}</p>}
  <a class="btn btn--coral pricing-card__cta" href="#lead-form">{page.pricing_cta ?? page.cta_text}</a>
</div>

<style>
  .pricing-card {
    border: 1px solid var(--color-black);
    padding: clamp(1.5rem, 4vw, 2rem);
    width: 100%;
    max-width: 22rem;
  }

  .pricing-card__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    max-width: none;
  }

  .pricing-card__label {
    margin-top: 0.75rem;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    max-width: none;
  }

  .pricing-card__amount {
    margin-top: 0.35rem;
    font-size: clamp(2.75rem, 2rem + 3vw, 4rem);
    font-weight: var(--font-weight-extrabold);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    max-width: none;
  }

  .pricing-card__currency {
    font-size: 0.55em;
    vertical-align: super;
    margin-right: 0.1em;
  }

  .pricing-card__text {
    margin-top: 0.875rem;
    font-size: var(--text-base);
    line-height: 1.45;
    max-width: none;
  }

  .pricing-card__cta {
    margin-top: 1.25rem;
    width: 100%;
    justify-content: center;
  }
</style>

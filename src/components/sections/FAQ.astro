---
import type { LandingPageData } from "@lib/types";

interface Props {
  page: LandingPageData;
  class?: string;
}

const { page, class: className = "" } = Astro.props;

if (!page.faq?.length) {
  return null;
}
---

<section class:list={["section", "faq", className]} id="faq" aria-labelledby="faq-heading">
  <div class="container split">
    <div class="faq__intro">
      <h2 id="faq-heading">{page.faq_heading ?? "Häufige Fragen"}</h2>
      {page.faq_intro && <p class="faq__intro-text">{page.faq_intro}</p>}
    </div>

    <div class="faq__list">
      {
        page.faq.map((item) => (
          <details class="faq__item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq__intro-text {
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  .faq__list {
    border-top: 1px solid var(--color-line);
  }

  .faq__item {
    border-bottom: 1px solid var(--color-line);
  }

  .faq__item summary {
    cursor: pointer;
    font-weight: var(--font-weight-semibold);
    font-size: var(--text-base);
    padding-block: 1.25rem;
    list-style: none;
  }

  .faq__item summary::-webkit-details-marker {
    display: none;
  }

  .faq__item p {
    padding-bottom: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: none;
  }
</style>

---
import LegalLayout from "@layouts/LegalLayout.astro";
import brand from "@data/brand";
---

<LegalLayout
  title="Seite nicht gefunden"
  description="Die angeforderte Seite wurde nicht gefunden."
>
  <div class="error">
    <p class="error__code" aria-hidden="true">404</p>
    <h1>Seite nicht gefunden</h1>
    <p>Die gesuchte Landingpage existiert nicht oder wurde verschoben.</p>
    <a class="btn btn--primary" href="/">Zur Übersicht</a>
    <p class="error__contact">
      Fragen? <a href={`mailto:${brand.contact.email}`}>{brand.contact.email}</a>
    </p>
  </div>
</LegalLayout>

<style>
  .error {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding-block: 2rem;
  }

  .error__code {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 7rem);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-brand-violet);
    opacity: 0.2;
    line-height: 1;
  }

  .error__contact {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>

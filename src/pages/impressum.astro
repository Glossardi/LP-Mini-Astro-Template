---
import LegalLayout from "@layouts/LegalLayout.astro";
import brand from "@data/brand";
---

<LegalLayout title="Impressum" description="Impressum und Anbieterkennzeichnung">
  <h1>Impressum</h1>

  <div class="legal-notice">
    <p>
      <strong>Hinweis:</strong> Vor dem Go-Live juristisch prüfen. Felder mit
      <code>[TODO]</code> ergänzen.
    </p>
  </div>

  <h2>Angaben gemäß § 5 TMG</h2>
  <address>
    <p>{brand.company}</p>
    <p>{brand.contact.address.street}</p>
    <p>{brand.contact.address.zip} {brand.contact.address.city}</p>
    <p>Deutschland</p>
  </address>

  <h2>Vertretungsberechtigte Person</h2>
  <p>[TODO: Geschäftsführung eintragen]</p>

  <h2>Kontakt</h2>
  <p>
    Telefon: <a href={`tel:${brand.contact.phone.replace(/\s/g, "")}`}>{brand.contact.phone}</a><br />
    E-Mail: <a href={`mailto:${brand.contact.email}`}>{brand.contact.email}</a>
  </p>

  <h2>Registerangaben</h2>
  <p>[TODO: Handelsregister / Registergericht]</p>

  <h2>Umsatzsteuer-ID</h2>
  <p>[TODO: USt-IdNr. falls vorhanden]</p>

  <h2>Verantwortlich für den Inhalt</h2>
  <p>[TODO: Verantwortliche Person gemäß § 55 Abs. 2 RStV]</p>
</LegalLayout>

<style>
  .legal-notice {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: var(--color-bg-coral);
    border-radius: var(--radius);
    font-size: var(--text-sm);
  }

  address {
    font-style: normal;
    margin-bottom: 1rem;
  }
</style>

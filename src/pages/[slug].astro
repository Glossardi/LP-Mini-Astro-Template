---
import { getCollection } from "astro:content";
import LandingLayout from "@layouts/LandingLayout.astro";

/** Dev: on-demand lookup — new markdown pages work without dev-server restart. */
export const prerender = import.meta.env.PROD;

export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ data }) => {
    if (import.meta.env.PROD) return data.published;
    return true;
  });

  return pages.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { page: entry.data },
  }));
}

interface Props {
  page?: import("@lib/types").LandingPageData;
}

const slug = Astro.params.slug;
let page = Astro.props.page;

if (!page && slug) {
  const pages = await getCollection("pages");
  const entry = pages.find((e) => e.data.slug === slug);
  if (!entry) return Astro.redirect("/404");
  page = entry.data;
}

if (!page) return Astro.redirect("/404");
---

<LandingLayout page={page} />

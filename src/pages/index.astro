---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/global/Nav.astro";
import Footer from "@components/global/Footer.astro";
import brand from "@data/brand";

const pages = await getCollection("pages", ({ data }) => {
  if (import.meta.env.PROD) return data.published;
  return true;
});

const sorted = pages.sort((a, b) => a.data.title.localeCompare(b.data.title, "de"));
---

<BaseLayout
  title="Landingpages"
  description="Schumm & Rösch — Agent-gestütztes Landing Page System"
  robots="noindex, nofollow"
>
  <Nav minimal />
  <main id="main-content" class="index">
    <div class="container">
      <p class="index__eyebrow">Schumm & Rösch</p>
      <h1>Landingpages</h1>
      <p class="index__intro">
        Neue Seiten: Markdown in <code>src/content/pages/</code> — siehe <code>AGENTS.md</code>.
      </p>

      <p class="index__hint">
        Lead-Magnet: <a href="/arbeitsplatz-fitness-check/">arbeitsplatz-fitness-check</a>
        · Showcase: <a href="/default-landing/">default-landing</a>
        · Event: <a href="/hr-konferenz-wiesbaden/">hr-konferenz-wiesbaden</a>
      </p>

      <ul class="index__list divider-list" role="list">
        {
          sorted.map((entry) => (
            <li class="divider-list__item index__item">
              <div>
                <a class="index__link" href={`/${entry.data.slug}/`}>
                  {entry.data.title}
                </a>
              </div>
              {!entry.data.published && <span class="index__badge">Entwurf</span>}
            </li>
          ))
        }
      </ul>

      <p class="index__note">
        <a href={brand.url}>schumms.com</a>
      </p>
    </div>
  </main>
  <Footer minimal />
</BaseLayout>

<style>
  .index {
    padding-block: clamp(4rem, 10vw, 7rem);
  }

  .index__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .index__intro {
    margin-top: 1.25rem;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 50ch;
  }

  .index__hint {
    margin-top: 0.75rem;
    font-size: var(--text-sm);
    max-width: none;
  }

  .index__hint a {
    font-weight: var(--font-weight-semibold);
  }

  .index code {
    font-size: 0.9em;
  }

  .index__list {
    margin-top: 3rem;
    max-width: 40rem;
  }

  .index__item {
    align-items: center;
    justify-content: space-between;
  }

  .index__link {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
  }

  .index__link:hover {
    text-decoration: underline;
  }

  .index__badge {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .index__note {
    margin-top: 3rem;
    font-size: var(--text-sm);
    max-width: none;
  }

  .index__note a {
    text-decoration: underline;
  }
</style>
